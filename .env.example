# Copy this file to .env and fill in the values marked with <your-value>.
# Everything else is pre-configured for local development.

# ── Application ────────────────────────────────────────────────────────────────
DEBUG=True

# ── Database ───────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/ai_job_copilot

# ── Session / Auth ─────────────────────────────────────────────────────────────
# Generate a long random string, e.g.: python -c "import secrets; print(secrets.token_hex(32))"
SESSION_SECRET_KEY=<your-secret-key>
SESSION_COOKIE_NAME=ai_job_copilot_session
SESSION_MAX_AGE_SECONDS=28800
SESSION_SAME_SITE=lax
SESSION_HTTPS_ONLY=False
SESSION_IDLE_TIMEOUT_SECONDS=1800
SESSION_ABSOLUTE_TIMEOUT_SECONDS=28800

# ── AI — OpenAI ────────────────────────────────────────────────────────────────
OPENAI_API_KEY=<your-openai-api-key>
OPENAI_MODEL=gpt-5-mini

# ── AI — CV Extraction (OpenRouter / Ollama) ───────────────────────────────────
# Set OPENROUTER_API_KEY to use the OpenRouter cloud endpoint for CV extraction.
# If omitted, the local Ollama instance (started by Docker Compose) is used instead.
# OPENROUTER_API_KEY=<your-openrouter-key>
OPENROUTER_API_URL=https://openrouter.ai/api/v1
LLM_API_URL=http://localhost:11434/v1
LLM_MODEL=qwen2.5:7b

# ── Job Search ─────────────────────────────────────────────────────────────────
# Use "fixture" during development — returns pre-recorded results with no API cost.
# Switch to "live" to call the real JSearch API (requires the JOB_API_* keys below).
JOB_SEARCH_PROVIDER=fixture
# JOB_API_BASE_URL=https://jsearch.p.rapidapi.com
# JOB_API_KEY=<your-rapidapi-key>
# JOB_API_HOST=jsearch.p.rapidapi.com

# ── LLM Observability (Langfuse) ───────────────────────────────────────────────
# These keys are pre-seeded in the dev Docker Compose setup — copy them as-is.
LANGFUSE_PUBLIC_KEY=pk-lf-dev-key
LANGFUSE_SECRET_KEY=sk-lf-dev-key
LANGFUSE_HOST=http://localhost:3000

# ── Logging ────────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FORMAT=json

# ── Document Storage (MinIO) ───────────────────────────────────────────────────
STORAGE_ENDPOINT_URL=http://localhost:9000
STORAGE_ACCESS_KEY=minioadmin
STORAGE_SECRET_KEY=minioadmin
STORAGE_BUCKET_NAME=ai-job-copilot-documents
STORAGE_REGION=us-east-1
MAX_UPLOAD_SIZE_BYTES=10485760
